<Window
    x:Class="ClassicLaunchpad.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- WinUI 3's Window has no Resources property, so resources live on the root Grid. -->
    <Grid x:Name="RootGrid">
        <Grid.Background>
            <SolidColorBrush Color="Black" Opacity="0.15"/>
        </Grid.Background>

        <Grid.Resources>
        <!-- Style for individual launchpad app button -->
        <Style x:Key="LaunchpadButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootElement" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             EnableDependentAnimation="True"
                                                             To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             EnableDependentAnimation="True"
                                                             To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             EnableDependentAnimation="True"
                                                             To="1.08" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             EnableDependentAnimation="True"
                                                             To="1.08" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             EnableDependentAnimation="True"
                                                             To="0.95" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             EnableDependentAnimation="True"
                                                             To="0.95" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ContentScale"/>
                            </Grid.RenderTransform>
                            
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="OpenFolderStoryboard">
            <DoubleAnimation Storyboard.TargetName="BackgroundGrid"
                             Storyboard.TargetProperty="Opacity"
                             To="0.35" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                             Storyboard.TargetProperty="ScaleX"
                             EnableDependentAnimation="True"
                             To="0.96" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                             Storyboard.TargetProperty="ScaleY"
                             EnableDependentAnimation="True"
                             To="0.96" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FolderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="1.0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="CloseFolderStoryboard">
            <DoubleAnimation Storyboard.TargetName="BackgroundGrid"
                             Storyboard.TargetProperty="Opacity"
                             To="1.0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                             Storyboard.TargetProperty="ScaleX"
                             EnableDependentAnimation="True"
                             To="1.0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                             Storyboard.TargetProperty="ScaleY"
                             EnableDependentAnimation="True"
                             To="1.0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FolderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="0.0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Main background contents container -->
        <Grid x:Name="BackgroundGrid" Grid.RowSpan="2" RenderTransformOrigin="0.5,0.5" Opacity="1.0">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="BackgroundScale" ScaleX="1.0" ScaleY="1.0"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- App Pages container (FlipView) -->
            <FlipView x:Name="AppsFlipView" Grid.Row="1"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      SelectionChanged="AppsFlipView_SelectionChanged">
            </FlipView>

            <!-- Page Dots indicator -->
            <StackPanel x:Name="PageDotsContainer" Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,10">
            </StackPanel>

            <!-- Search capsule -->
            <Border Grid.Row="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#66000000"
                    BorderBrush="#20FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Width="320"
                    Height="36"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#AAFFFFFF" Margin="12,0,8,0"/>
                    
                    <TextBox x:Name="SearchBox" Grid.Column="1"
                             PlaceholderText="Search"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="14"
                             VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown">
                        <TextBox.Resources>
                            <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                            <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                        </TextBox.Resources>
                    </TextBox>

                    <Button x:Name="ClearSearchButton" Grid.Column="2"
                            Content="&#xE894;" FontFamily="Segoe MDL2 Assets"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#AAFFFFFF" FontSize="12" Margin="0,0,8,0"
                            Visibility="Collapsed" Click="ClearSearchButton_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Folder Overlay Popup -->
        <Grid x:Name="FolderOverlay" Grid.RowSpan="5"
              AllowDrop="True"
              DragOver="FolderOverlay_DragOver"
              Drop="FolderOverlay_Drop"
              Visibility="Collapsed"
              Opacity="0.0"
              PointerPressed="FolderOverlay_PointerPressed">
            <Grid.Background>
                <SolidColorBrush Color="Black" Opacity="0.6"/>
            </Grid.Background>
            <Border x:Name="FolderCardBorder" AllowDrop="True"
                    DragOver="FolderCardBorder_DragOver"
                    Drop="FolderCardBorder_Drop"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#22FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1.5"
                    CornerRadius="24" Padding="32" Width="600" Height="450">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBox x:Name="FolderNameTextBox"
                             Text="Folder Name"
                             Foreground="White"
                             FontSize="24"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"
                             Background="Transparent"
                             BorderThickness="0,0,0,1"
                             BorderBrush="Transparent"
                             TextAlignment="Center"
                             LostFocus="FolderNameTextBox_LostFocus"
                             KeyDown="FolderNameTextBox_KeyDown"/>

                    <ScrollViewer Grid.Row="1" Margin="0,20,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="FolderAppsGrid">
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Math Result Quick Action Card Overlay -->
        <Border x:Name="MathResultCard" Grid.Row="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                CornerRadius="16" Width="500" Padding="16" Visibility="Collapsed"
                PointerPressed="MathResultCard_PointerPressed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#400A84FF" CornerRadius="12" Width="50" Height="50" Margin="0,0,16,0">
                    <TextBlock x:Name="MathResultGlyph" Text="=" Foreground="White" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="MathResultText" Text="Result" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock x:Name="MathResultSubText" Text="Calculation Result (Click to Copy)" Foreground="#AAFFFFFF" FontSize="13"/>
                </StackPanel>

                <FontIcon Grid.Column="2" Glyph="&#xE00F;" FontSize="14" Foreground="#66FFFFFF" Margin="12,0,8,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
