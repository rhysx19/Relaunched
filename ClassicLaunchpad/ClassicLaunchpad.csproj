<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- On Windows, compile as a WinExe targeting Windows 10. On macOS, target standard net8.0 console executable. -->
    <OutputType Condition="$([MSBuild]::IsOSPlatform('windows'))">WinExe</OutputType>
    <OutputType Condition="!$([MSBuild]::IsOSPlatform('windows'))">Exe</OutputType>
    
    <TargetFramework Condition="$([MSBuild]::IsOSPlatform('windows'))">net8.0-windows10.0.19041.0</TargetFramework>
    <TargetFramework Condition="!$([MSBuild]::IsOSPlatform('windows'))">net8.0</TargetFramework>
    
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>ClassicLaunchpad</RootNamespace>
    <AssemblyName>ClassicLaunchpad</AssemblyName>
    
    <!-- WinUI 3 details (only active when building on Windows) -->
    <UseWinUI Condition="$([MSBuild]::IsOSPlatform('windows'))">true</UseWinUI>
    <WindowsPackageType Condition="$([MSBuild]::IsOSPlatform('windows'))">None</WindowsPackageType>
    
    <!-- Supported platform builds -->
    <Platforms>AnyCPU;x64;x86;ARM64</Platforms>
    <RuntimeIdentifiers>win-x64;win-x86;win-arm64</RuntimeIdentifiers>
  </PropertyGroup>

  <!-- Windows-only dependencies and packages -->
  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('windows'))">
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.6.241114003" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.174" />
  </ItemGroup>

  <!-- Shared dependency to Core library -->
  <ItemGroup>
    <ProjectReference Include="..\ClassicLaunchpad.Core\ClassicLaunchpad.Core.csproj" />
  </ItemGroup>

  <!-- Non-Windows configuration: Exclude WinUI XAML and C# files, compile only the Stub.cs -->
  <ItemGroup Condition="!$([MSBuild]::IsOSPlatform('windows'))">
    <Compile Remove="**/*.cs" />
    <Page Remove="**/*.xaml" />
    
    <!-- Leave them visible as items in IDE but not compiled -->
    <None Include="**/*.cs" />
    <None Include="**/*.xaml" />
    
    <!-- Compile the stub -->
    <Compile Include="Stub.cs" />
  </ItemGroup>

</Project>
